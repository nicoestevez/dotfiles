{
    "files.autoSave": "afterDelay",
    "workbench.iconTheme": "material-icon-theme",
    "jupyter.askForKernelRestart": false,
    "remote.autoForwardPortsSource": "hybrid",
    "svelte.enable-ts-plugin": true,
    "files.associations": {
        "*.h": "c",
        "*.py": "python",
        "*.prisma": "prisma"
    },
    "liveServer.settings.donotShowInfoMsg": true,
    "notebook.editorOptionsCustomizations": {
        "editor.tabSize": 4,
        "editor.indentSize": 4
    },
    "github.copilot.editor.enableAutoCompletions": true,
    "editor.lineNumbers": "relative",
    "typescript.updateImportsOnFileMove.enabled": "always",
    "pylint.args": [
        "--disable=C0114,C0115,C0116,E0611,E1101,R0903",
        "--max-line-length=120"
    ],
    "dataWrangler.startInEditModeForNotebookEntrypoints": true,
    "terminal.integrated.gpuAcceleration": "off",
    "git.autofetch": true,
    "chat.mcp.gallery.enabled": true,
    "chat.mcp.discovery.enabled": {
        "claude-desktop": true,
        "windsurf": true,
        "cursor-global": true,
        "cursor-workspace": true
    }, "gitlens.ai.model": "vscode", "gitlens.ai.vscode.model": "copilot:gpt-4.1", "[python]": { "editor.defaultFormatter": "ms-python.black-formatter"
    },
    "chatgpt.runCodexInWindowsSubsystemForLinux": true,
    "editor.inlineSuggest.experimental.showOnSuggestConflict": "always",
    "claudeCode.preferredLocation": "panel",
    "git.confirmSync": false,
    "js/ts.updateImportsOnFileMove.enabled": "always",
    "workbench.editor.enablePreviewFromCodeNavigation": true,
    "githubPullRequests.pullBranch": "never",
    "settingsSync.keybindingsPerPlatform": false,
    "vim.useCtrlKeys": false,
    "vim.handleKeys": {
        "<C-r>": true,
        "<C-v>": true,
        "<C-d>": true,
        "<C-u>": true
    },
    "git.replaceTagsWhenPull": true
}